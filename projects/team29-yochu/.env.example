SOLAR_API_KEY=your_upstage_api_key_here
SOLAR_BASE_URL=https://api.upstage.ai/v1
SOLAR_MODEL=solar-pro3
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=asm-team29-ai-study
AGENT1_DETECTOR_BACKEND=owlv2
AGENT1_DETECTOR_MODEL=google/owlv2-base-patch16-ensemble
AGENT1_DETECTOR_THRESHOLD=0.25
# 비워두면 agents/agent1/ingredient_aliases.py의 기본 detector label을 사용합니다.
AGENT1_DETECTOR_LABELS=
AGENT1_ANNOTATION_OUTPUT_DIR=runtime_outputs/agent1
