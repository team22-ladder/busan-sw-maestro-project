# ===========================================================================
# Prompt Arena Backend — 환경 변수 예시
#
# 사용 방법:
#   cp .env.example .env  후 값을 채워 넣고, run.py 또는 uvicorn 으로 실행.
#   docs/how_to_use_api_key.md 참고.
# ===========================================================================

# --- Upstage Solar API (운영 채점) ---
# 비워두면 자동으로 Mock 백엔드를 사용한다 (테스트/데모 가능).
UPSTAGE_API_KEY=
UPSTAGE_BASE_URL=https://api.upstage.ai/v1/solar

# --- 대전 엔진 ---
ARENA_AI_BACKEND=upstage           # mock | upstage
ARENA_TIME_LIMIT=180               # 프롬프트 작성 제한 시간(초)
ARENA_MAX_PROMPT_LENGTH=1200       # 프롬프트 최대 글자 수
ARENA_AI_MAX_RETRIES=3             # AI 호출 재시도 횟수
ARENA_DEFAULT_MODEL=solar-pro3     # 과제 풀의 기본 모델명
ARENA_BANNED_WORDS=                # 콤마 구분 추가 금칙어 (선택)

# --- 세션/Redis ---
# 비워두면 InMemorySessionStore 사용 (단일 프로세스 한정).
# docker compose up -d redis 후:
#   REDIS_URL=redis://localhost:6379/0
REDIS_URL=
SESSION_TTL_SECONDS=86400          # 세션 토큰 TTL (24h)

# --- PostgreSQL ---
# docker compose up -d postgres 후:
#   DATABASE_URL=postgresql+asyncpg://arena:arena_password@localhost:5432/prompt_arena
DATABASE_URL=
