# =========================================================
# .env.template
# 사용법: 이 파일을 복사해 `.env` 파일을 만들고,
#         your_key 부분에 실제 발급받은 키를 입력하세요.
#         (.env 는 .gitignore 로 추적 제외되어 깃허브에 노출되지 않습니다.)
# =========================================================

# Upstage Solar API Key
UPSTAGE_API_KEY=your_key

# LangSmith 관측성(Observability) 및 모니터링 설정
LANGSMITH_TRACING_V2=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com/"
LANGSMITH_API_KEY=your_key
LANGSMITH_PROJECT="travel-agentic-workflow"

# Kakao REST API 키 (지오코딩 + 거리 계산)
KAKAO_API_KEY=your_key

# OpenWeather API 키 (날씨 예보)
OPENWEATHER_API_KEY=your_key
