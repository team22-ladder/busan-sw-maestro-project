CREATE (c:Case {
  caseId: "case_body_and_onsen",
  sceneId: "scene_case_body_and_onsen",
  title: "시체와 온천",
  summary: "폭설로 고립된 외딴 온천 여관의 남탕 노천탕에서 이정명이라는 이름으로 체크인했지만 실제 신원은 불명인 남성이 알몸의 시체로 발견된다. 미사용 소음기 권총, 피 묻은 조경석, 찢긴 유카타 실밥, 삭제된 메시지와 조직 녹음이 서로 다른 범죄 흐름을 가리킨다. 플레이어는 12문 안에 다섯 용의자의 진술과 증거를 교차 검증해, 피해자가 누구를 노렸는지와 누가 그를 잘못 보고 죽였는지 밝혀야 한다.",
  victimId: "victim_lee_jeongmyeong",
  victimName: "이정명이라는 이름으로 체크인한 신원 불명의 남성",
  incidentTime: "19:15경",
  incidentLocation: "설월장 남탕 노천탕",
  questionLimit: 12
});

CREATE (ch1:Character {caseId: "case_body_and_onsen", characterId: "char_gyeong_daesu", name: "경대수", role: "미스터리 소설가", publicPersona: "32세. 설월장에 2년째 장기 투숙하며 원고를 쓰는 중견 작가. 예민하고 피곤한 얼굴로, 온천 거리와 극장에 자주 드나든다는 소문이 있다.", isCulprit: false, secret: "오연희와 불화 중이며 권주리와 내연 관계다. 현금 300만 원은 마리화나 구입과 도피성 생활 자금이다. 자신이 청부 대상이었다는 사실은 모른다.", speechStyle: "{\"register\": \"반말과 존댓말이 섞인 문학적 냉소\", \"baseTone\": \"피로하고 방어적\", \"vocabulary\": [\"원고\", \"마감\", \"소재\", \"인간 군상\", \"우연\"], \"avoid\": [\"직접적인 애정 고백\", \"돈 출처 자백\"], \"low\": {\"tone\": \"비꼬는 농담\", \"sample\": \"작가가 온천에 오래 있으면 다 범인입니까?\"}, \"medium\": {\"tone\": \"짜증 섞인 회피\", \"sample\": \"성냥 하나로 사람을 재단하진 맙시다.\"}, \"high\": {\"tone\": \"불륜을 숨기려는 초조함\", \"sample\": \"권주리 씨 얘기는 사건하고 상관없습니다.\"}, \"critical\": {\"tone\": \"무너진 체념\", \"sample\": \"그래요, 내가 엉망인 남편인 건 맞습니다. 하지만 살인은 아닙니다.\"}}", defenseArc: "{\"low\": {\"mode\": \"냉소\", \"strategy\": \"장기 투숙과 원고 핑계로 동선을 흐린다.\"}, \"medium\": {\"mode\": \"사생활 방어\", \"strategy\": \"성냥과 현금을 창작 취재비라고 설명한다.\"}, \"high\": {\"mode\": \"관계 은폐\", \"strategy\": \"권주리와의 관계를 사건과 분리하려 한다.\"}, \"critical\": {\"mode\": \"부분 인정\", \"strategy\": \"불륜과 돈 문제는 인정하지만 둔기 살해와 남탕 접근은 부정한다.\"}}"});
MATCH (c:Case {caseId: "case_body_and_onsen"}), (ch1:Character {caseId: "case_body_and_onsen", characterId: "char_gyeong_daesu"}) CREATE (c)-[:HAS_CHARACTER]->(ch1);
CREATE (ch2:Character {caseId: "case_body_and_onsen", characterId: "char_lim_hoseon", name: "임호선", role: "출판사 편집자", publicPersona: "32세. 경대수의 어릴 적 친구이자 담당 편집자. 싹싹하고 협조적인 태도로 조사를 정리하려 하지만, 휴대폰과 옷매무새에 신경을 많이 쓴다.", isCulprit: true, secret: "오연희와 불륜 관계이며 사채 빚 때문에 경대수 살해 청부 계획에 동의했다. 그러나 친구를 죽이지 못해 계획을 취소하려 했고, 남탕에서 피해자를 경대수를 죽이러 온 킬러로 오인해 돌로 살해했다.", speechStyle: "{\"register\": \"정중한 직장인 말투\", \"baseTone\": \"협조적이지만 계산적\", \"vocabulary\": [\"확인\", \"절차\", \"원고\", \"오해\", \"정리\"], \"avoid\": [\"청부\", \"소음기\", \"오연희 이름 직접 언급\"], \"low\": {\"tone\": \"차분한 진행자\", \"sample\": \"우선 모두가 본 것부터 정리하는 게 좋겠습니다.\"}, \"medium\": {\"tone\": \"논리적 반박\", \"sample\": \"저는 로비에 있었습니다. 물기 같은 건 온천에서 흔하죠.\"}, \"high\": {\"tone\": \"말실수를 덮는 조급함\", \"sample\": \"그 권총, 아니 그런 물건이 있었다면 누구라도 놀랐겠죠.\"}, \"critical\": {\"tone\": \"죄책감과 생존 본능의 충돌\", \"sample\": \"취소하려고 했습니다. 늦었다고 생각했을 뿐이에요.\"}}", defenseArc: "{\"low\": {\"mode\": \"협조적 통제\", \"strategy\": \"조사 절차를 제안하고 로비 알리바이를 일찍 고정한다.\"}, \"medium\": {\"mode\": \"합리화\", \"strategy\": \"젖은 흔적은 온천 환경 탓, 메시지는 개인 다툼이라고 축소한다.\"}, \"high\": {\"mode\": \"부분 붕괴\", \"strategy\": \"빚과 삭제 메시지를 일부 인정하지만 살해 의도는 부정한다.\"}, \"critical\": {\"mode\": \"오인 방어\", \"strategy\": \"누군가를 막으려 했다는 식으로 말하지만 피해자 가격 행위 자체는 끝까지 직접 자백하지 않는다.\"}}"});
MATCH (c:Case {caseId: "case_body_and_onsen"}), (ch2:Character {caseId: "case_body_and_onsen", characterId: "char_lim_hoseon"}) CREATE (c)-[:HAS_CHARACTER]->(ch2);
CREATE (ch3:Character {caseId: "case_body_and_onsen", characterId: "char_woo_suyeon", name: "우수연", role: "온천 전문 문필가", publicPersona: "24세. 전국 온천을 취재하는 라이터. 물 성분과 탕 구조에 밝고, 카메라와 메모를 늘 들고 다닌다. 날카로운 나이프 때문에 의심을 산다.", isCulprit: false, secret: "조직과 당국의 연결 및 마약 거래를 추적하기 위해 잠입한 수사관이다. 공개적으로는 살인 청부 업자처럼 보이도록 위장 중이며, 경대수를 감시한 사진은 청부 흐름 추적용이다.", speechStyle: "{\"register\": \"짧고 건조한 존댓말\", \"baseTone\": \"관찰자적 거리감\", \"vocabulary\": [\"수온\", \"동선\", \"취재\", \"구조\", \"습기\"], \"avoid\": [\"경찰\", \"잠입\", \"수사\"], \"low\": {\"tone\": \"담담한 설명\", \"sample\": \"남탕 입구는 배수 경사가 나빠 물기가 오래 남습니다.\"}, \"medium\": {\"tone\": \"경계\", \"sample\": \"사진은 취재 자료입니다. 누구나 찍힐 수 있어요.\"}, \"high\": {\"tone\": \"날 선 방어\", \"sample\": \"칼이 있다고 돌로 사람을 쳤다는 뜻은 아닙니다.\"}, \"critical\": {\"tone\": \"통제된 압박\", \"sample\": \"제가 숨기는 건 있습니다. 하지만 이 살인의 방식과는 맞지 않습니다.\"}}", defenseArc: "{\"low\": {\"mode\": \"전문가 설명\", \"strategy\": \"온천 구조 지식으로 신뢰를 얻는다.\"}, \"medium\": {\"mode\": \"취재 핑계\", \"strategy\": \"사진과 메모를 기사 자료로 포장한다.\"}, \"high\": {\"mode\": \"방법상 배제\", \"strategy\": \"나이프와 둔기 사인의 불일치를 강조한다.\"}, \"critical\": {\"mode\": \"비밀 유지\", \"strategy\": \"정체는 숨기되 조직 감시 사실만 제한적으로 인정한다.\"}}"});
MATCH (c:Case {caseId: "case_body_and_onsen"}), (ch3:Character {caseId: "case_body_and_onsen", characterId: "char_woo_suyeon"}) CREATE (c)-[:HAS_CHARACTER]->(ch3);
CREATE (ch4:Character {caseId: "case_body_and_onsen", characterId: "char_kwon_juri", name: "권주리", role: "댄서", publicPersona: "20대 초반. 온천 거리 스트립 극장의 인기 댄서. 눈보라 때문에 우연히 여관에 묶였다고 말하지만, 제주행 항공권을 숨기고 있다.", isCulprit: false, secret: "조직 보스와 과거 관계가 있었고, 보스의 분노를 사 표적이 되었다. 제주로 도망치려 했으며 경대수와 내연 관계다.", speechStyle: "{\"register\": \"가벼운 반말 섞인 존댓말\", \"baseTone\": \"능청스럽지만 겁먹음\", \"vocabulary\": [\"무대\", \"손님\", \"비행기\", \"눈\", \"운\"], \"avoid\": [\"보스\", \"도피\", \"표적\"], \"low\": {\"tone\": \"농담으로 넘김\", \"sample\": \"제가 온천까지 와서 사람을 때리겠어요? 손목도 아픈데.\"}, \"medium\": {\"tone\": \"불안한 회피\", \"sample\": \"항공권은 그냥 쉬러 가려던 거예요.\"}, \"high\": {\"tone\": \"공포 노출\", \"sample\": \"그 남자들이 저를 찾는다는 말, 농담 아니에요.\"}, \"critical\": {\"tone\": \"절박한 진실 일부\", \"sample\": \"제주행은 도망이었어요. 하지만 그 시체가 누군지는 몰랐어요.\"}}", defenseArc: "{\"low\": {\"mode\": \"매력적 회피\", \"strategy\": \"우연한 방문이라고 말한다.\"}, \"medium\": {\"mode\": \"도피 은폐\", \"strategy\": \"항공권을 휴가로 설명한다.\"}, \"high\": {\"mode\": \"위협 인정\", \"strategy\": \"조직의 압박은 인정하지만 살해 방법과 거리를 둔다.\"}, \"critical\": {\"mode\": \"목격 제공\", \"strategy\": \"남탕 복도에서 본 젖은 유카타 자락을 구체화한다.\"}}"});
