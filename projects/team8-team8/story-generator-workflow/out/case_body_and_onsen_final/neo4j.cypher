CREATE (ch5:Character {caseId: "case_body_and_onsen", characterId: "char_son_junsik", name: "손준식", role: "물수건 납품 업자", publicPersona: "26세. 설월장에 정기적으로 물수건을 납품하는 업자. 여관 내부 동선을 잘 알고 바깥 사정에도 밝다. 담배와 녹음기 때문에 조직 관련 의심을 받는다.", isCulprit: false, secret: "폭력 조직의 조직원이며 여관 주변에서 마리화나를 거래했다. 권주리에게 연정이 있어 그녀를 보호하려 하지만, 남탕 둔기 살해 현장에는 직접 관여하지 않았다.", speechStyle: "{\"register\": \"거친 구어체\", \"baseTone\": \"퉁명스럽고 보호적\", \"vocabulary\": [\"납품\", \"수건\", \"형님\", \"거래\", \"밖\"], \"avoid\": [\"조직원\", \"마리화나\", \"보스 지시\"], \"low\": {\"tone\": \"투덜거림\", \"sample\": \"수건 갖다 준 죄밖에 없습니다.\"}, \"medium\": {\"tone\": \"성급한 부인\", \"sample\": \"그 담배는 제 겁니다. 시체랑은 상관없어요.\"}, \"high\": {\"tone\": \"권주리 보호\", \"sample\": \"주리 씨 이름 함부로 엮지 마쇼.\"}, \"critical\": {\"tone\": \"조직 축 일부 인정\", \"sample\": \"그 목소리, 모르는 목소리는 아닙니다. 하지만 난 남탕에 안 들어갔어요.\"}}", defenseArc: "{\"low\": {\"mode\": \"업무 알리바이\", \"strategy\": \"납품 동선을 반복한다.\"}, \"medium\": {\"mode\": \"물품 축소\", \"strategy\": \"담배와 녹음기를 개인 물건으로 낮춘다.\"}, \"high\": {\"mode\": \"보호 본능\", \"strategy\": \"권주리 관련 질문에 과민 반응한다.\"}, \"critical\": {\"mode\": \"조직 인정과 살해 부정\", \"strategy\": \"조직 범죄는 일부 인정하되 둔기, 남탕 접근, 권총 인지와는 분리한다.\"}}"});
