CREATE (st6:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_weapon_slip", characterId: "", text: "소음기까지 달린 물건이면 보통 일이 아니잖습니까. ...아니, 발견 때 누가 그렇게 말했을 겁니다.", questionText: "", timeWindow: "", location: "", initiallyVisible: true, unlockCondition: ""});
