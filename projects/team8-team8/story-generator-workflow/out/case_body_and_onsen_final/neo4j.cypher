CREATE (st2:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_message_claim", characterId: "", text: "그 메시지는 개인적인 말다툼입니다. 삭제한 건 민망해서였고, 사건과는 상관없습니다.", questionText: "", timeWindow: "", location: "", initiallyVisible: true, unlockCondition: ""});
MATCH (c:Case {caseId: "case_body_and_onsen"}), (st2:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_message_claim"}) CREATE (c)-[:HAS_STATEMENT]->(st2);
CREATE (st3:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_debt_partial_admission", characterId: "", text: "빚이 있는 건 맞습니다. 그래서 돈 얘기에 예민했지만, 누굴 죽여서 해결하려 한 건 아닙니다.", questionText: "", timeWindow: "", location: "", initiallyVisible: true, unlockCondition: ""});
MATCH (c:Case {caseId: "case_body_and_onsen"}), (st3:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_debt_partial_admission"}) CREATE (c)-[:HAS_STATEMENT]->(st3);
CREATE (st4:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_stone_evasion", characterId: "", text: "그 돌은 탕 주변에 늘 있던 겁니다. 젖은 손으로 들면 미끄러웠겠죠. 아니, 제가 들어봤다는 뜻은 아닙니다.", questionText: "", timeWindow: "", location: "", initiallyVisible: true, unlockCondition: ""});
MATCH (c:Case {caseId: "case_body_and_onsen"}), (st4:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_stone_evasion"}) CREATE (c)-[:HAS_STATEMENT]->(st4);
CREATE (st5:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_no_weapon_claim", characterId: "", text: "권총이 있었다는 건 시체 발견 뒤에 알았습니다. 전 그 바구니를 만진 적 없습니다.", questionText: "", timeWindow: "", location: "", initiallyVisible: true, unlockCondition: ""});
