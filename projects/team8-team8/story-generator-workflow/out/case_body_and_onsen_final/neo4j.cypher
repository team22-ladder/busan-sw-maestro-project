CREATE (st7:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_cancel_slip", characterId: "", text: "사람은 마음을 바꿀 수 있습니다. 이미 시작된 일을 멈춰 달라고 해도... 상대가 듣지 않으면 어떻게 합니까.", questionText: "", timeWindow: "", location: "", initiallyVisible: true, unlockCondition: ""});
