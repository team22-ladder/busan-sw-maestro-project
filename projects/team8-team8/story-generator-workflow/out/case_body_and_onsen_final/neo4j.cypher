CREATE (sol:Solution {caseId: "case_body_and_onsen", culpritId: "char_lim_hoseon", motive: "임호선은 오연희와 함께 경대수 살해 청부에 발을 들였으나 친구를 죽이지 못해 취소하려 했다. 남탕에서 권총을 본 뒤 피해자를 경대수를 죽이러 온 킬러로 오인했고, 취소가 받아들여지지 않는다고 판단해 공포와 죄책감 속에서 선제적으로 살해했다.", method: "임호선은 남탕 탈의실과 탕가에 접근해 피해자의 바구니와 권총을 확인했다. 피해자가 방심해 돌아선 순간 탕 주변 조경석으로 후두부를 가격했고, 시체를 탕에 띄운 뒤 옷과 바구니를 정리해 발견 시점을 흐렸다.", requiredContradictionIds: "[\"con_hoseon_bath_access\", \"con_hoseon_weapon_awareness\", \"con_hoseon_cancelled_contract\", \"con_victim_target_misdirection\"]", requiredEvidenceIds: "[\"ev_bloodied_stone\", \"ev_hoseon_yukata_tear\", \"ev_pistol_oil_on_hoseon_hand\", \"ev_hoseon_phone_message\", \"ev_victim_juri_photo_schedule\"]", requiredStatementIds: "[\"st_juri_saw_wet_corridor\", \"st_hoseon_weapon_slip\", \"st_hoseon_cancel_slip\", \"st_junsik_outsider_hint\"]"});
MATCH (c:Case {caseId: "case_body_and_onsen"}), (sol:Solution {caseId: "case_body_and_onsen"}) CREATE (c)-[:HAS_SOLUTION]->(sol);
