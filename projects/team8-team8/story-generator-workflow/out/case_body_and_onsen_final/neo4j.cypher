CREATE (st1:Statement {caseId: "case_body_and_onsen", statementId: "st_hoseon_lobby_claim", characterId: "", text: "저는 7시쯤부터 로비 전화기 옆에 있었습니다. 대수 원고 때문에 연락을 기다렸어요.", questionText: "", timeWindow: "", location: "", initiallyVisible: true, unlockCondition: ""});
