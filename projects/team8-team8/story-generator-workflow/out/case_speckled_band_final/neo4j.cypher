CREATE (ch1:Character {caseId: "case_speckled_band", characterId: "char_grimesby_roylott", name: "그림즈비 로일롯 박사", role: "의붓아버지", publicPersona: "인도 체류 경력이 있는 폭력적인 의사. 저택과 헬렌을 통제하며 딸들의 결혼 문제에 과민하다.", isCulprit: true, secret: "지참금을 막기 위해 줄리아를 살해했고 헬렌에게 같은 수법을 반복하려 한다. 금고에 늪살무사를 숨겼다.", speechStyle: "{\"register\": \"위압적 존댓말과 명령형\", \"baseTone\": \"분노와 조롱\", \"vocabulary\": [\"내 집\", \"참견\", \"사업 서류\", \"인도\", \"힘\"], \"avoid\": [\"정답 도구명\", \"살해\", \"지참금 범행\"], \"low\": {\"tone\": \"비웃음\", \"sample\": \"런던식 추리로 내 집을 재단하지 마시오.\"}, \"medium\": {\"tone\": \"차가운 협박\", \"sample\": \"그 방은 밀실이었고, 그게 전부입니다.\"}, \"high\": {\"tone\": \"노골적 위협\", \"sample\": \"더 캐묻는다면 그 쇠막대기처럼 구부려 놓겠소.\"}, \"critical\": {\"tone\": \"궁지의 격노\", \"sample\": \"금고 이야기는 그만하시오. 내 방에 손댄 자는 후회합니다.\"}}", defenseArc: "{\"low\": {\"mode\": \"dismiss\", \"strategy\": \"검시 보고서와 밀실을 내세워 자연사로 몰아간다.\"}, \"medium\": {\"mode\": \"redirect\", \"strategy\": \"얼룩무늬 스카프를 든 집시들에게 의심을 돌린다.\"}, \"high\": {\"mode\": \"intimidate\", \"strategy\": \"부중을 굽히며 질문 페널티를 유도한다.\"}, \"critical\": {\"mode\": \"split_evidence\", \"strategy\": \"환기구, 벨줄, 우유, 채찍, 금고를 각각 무해한 물건으로 분리해 방어한다.\"}}"});
