CREATE (sol:Solution {caseId: "case_speckled_band", culpritId: "char_grimesby_roylott", motive: "헬렌과 줄리아가 결혼하면 지참금을 지급해야 하므로 로일롯은 재정 파탄을 피하려 했다.", method: "로일롯은 철제 금고에 늪살무사를 숨기고 밤마다 환기구로 보냈다. 뱀은 가짜 벨줄을 타고 고정 침대의 피해자에게 내려갔고, 로일롯은 휘파람과 우유로 뱀을 회수했다. '얼룩무늬 밴드'는 집시 스카프가 아니라 뱀의 노란 바탕과 갈색 반점을 뜻한다.", requiredContradictionIds: "[\"con_motive_denial\", \"con_sealed_room_internal_route\", \"con_safe_documents_animal_tools\", \"con_gypsy_insufficient_link\"]", requiredEvidenceIds: "[\"ev_mothers_will\", \"ev_fake_bell_pull\", \"ev_ventilator\", \"ev_fixed_bed\", \"ev_milk_saucer\", \"ev_looped_whip\", \"ev_iron_safe\", \"ev_coroner_report\"]", requiredStatementIds: "[\"st_roylott_natural_death\", \"st_roylott_safe_documents\", \"st_roylott_no_motive\", \"st_housekeeper_repairs\", \"st_helen_whistle\"]"});
MATCH (c:Case {caseId: "case_speckled_band"}), (sol:Solution {caseId: "case_speckled_band"}) CREATE (c)-[:HAS_SOLUTION]->(sol);
