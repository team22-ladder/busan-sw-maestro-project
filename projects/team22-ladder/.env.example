# 실제 사용 시 .env 파일로 복사해서 값을 채워주세요
# cp .env.example .env

# Gemini API - 냉장고 사진에서 재료 추출에 사용
# https://aistudio.google.com/app 에서 API Key 발급
GEMINI_API_KEY=

# Solar API (Upstage) - 레시피 생성 및 재료명 번역에 사용
# https://console.upstage.ai 에서 API Key 발급
UPSTAGE_API_KEY=
UPSTAGE_SOLAR_MODEL=solar-pro3

# Unsplash API - 재료 이미지 검색에 사용 (선택)
# https://unsplash.com/developers 에서 앱 등록 후 Access Key 발급
UNSPLASH_ACCESS_KEY=

# YouTube Data API - 레시피 영상 썸네일 조회에 사용 (선택)
# https://console.cloud.google.com 에서 YouTube Data API v3 활성화 후 발급
YOUTUBE_API_KEY=

# Backend API URL - 프론트엔드에서 백엔드 호출 시 사용
API_URL=http://localhost:8000
