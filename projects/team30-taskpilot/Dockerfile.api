FROM python:3.11-slim
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
WORKDIR /app
COPY pyproject.toml .
COPY uv.lock .
RUN uv sync
COPY app/ app/
COPY backend/ backend/
COPY tests/ tests/
EXPOSE 8001
CMD ["uv", "run", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8001"]
# Railway에서는 railway.toml의 startCommand가 PORT 환경변수를 사용하므로 위 CMD는 로컬 전용
