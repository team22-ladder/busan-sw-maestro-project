# LLM (Upstage Solar)
UPSTAGE_API_KEY=

# MySQL (RDB) — 로컬 docker-compose 기본값
DATABASE_URL=mysql+pymysql://app:app@localhost:3306/minecraft

# Qdrant (Vector DB)
# (A) 로컬 docker-compose 사용 시 ↓
QDRANT_HOST=localhost
QDRANT_PORT=6333
# (B) 공유 Qdrant Cloud 사용 시 ↓ (설정하면 위 host/port 대신 우선 사용)
# QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=minecraft_knowledge

# 위키 적재 소스 (scripts/ingest_wiki.py) — 데이터 수집자만 필요
WIKI_VAULT_PATH=~/obsidian/minecraftwiki

# 관측(선택)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# 프론트엔드 ↔ 백엔드
BACKEND_URL=http://127.0.0.1:8001
CORS_ORIGINS=http://127.0.0.1:8002
